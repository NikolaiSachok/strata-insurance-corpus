# The full generated corpus is reproducible (make generate) + published to HuggingFace.
# Do NOT commit it — only the small committed sample/ slice lives in git.
/corpus/
*.qdrant/

# Raw AI-image generation outputs (the /generate-image skill writes here). Finalized,
# committed pixels live under sample/ (faces/, evidence/); these working originals do not.
/generated_images/

# LLM content cache (keyed by seed+doc_id; reproducible, not source)
.cache/
.llm-cache/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
build/
dist/

# OS / editor
.DS_Store
.env
.idea/
.vscode/
