<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>{{ claim_id }} — FNOL</title></head>
<body>
  <div class="synthetic-banner">{{ marker }}</div>
  <div class="masthead">
    <div class="company">{{ company }}</div>
    <div class="doc-title">{{ doc_title }}</div>
  </div>

  <h2>Claim Summary</h2>
  <table class="kv">
    <tr><td class="k">Claim number</td><td class="v">{{ claim_id }}</td></tr>
    <tr><td class="k">Policy number</td><td class="v">{{ policy_id }}</td></tr>
    <tr><td class="k">Line of business</td><td class="v">{{ line_label }}</td></tr>
    <tr><td class="k">Date of loss</td><td class="v">{{ date_of_loss }}</td></tr>
    <tr><td class="k">Date reported</td><td class="v">{{ reported_date }}</td></tr>
    <tr><td class="k">Cause of loss</td><td class="v">{{ cause_label }}</td></tr>
    <tr><td class="k">Claim status</td><td class="v"><span class="status {{ status }}">{{ status }}</span></td></tr>
    {% if vehicle %}<tr><td class="k">Insured vehicle</td><td class="v">{{ vehicle }}</td></tr>{% endif %}
    <tr><td class="k">Current reserve</td><td class="v">{{ reserve }}</td></tr>
  </table>

  <h2>Reporting Party</h2>
  <table class="kv">
    <tr><td class="k">Insured</td><td class="v">{{ holder_name }}</td></tr>
    <tr><td class="k">Phone</td><td class="v">{{ holder_phone }}</td></tr>
    <tr><td class="k">Email</td><td class="v">{{ holder_email }}</td></tr>
    <tr><td class="k">Assigned adjuster</td><td class="v">{{ adjuster_name }} ({{ adjuster_specialty }})</td></tr>
  </table>

  <h2>Description of Loss</h2>
  <p class="narrative">{{ narrative }}</p>

  <p class="meta-foot">This document is synthetic and generated for retrieval/benchmark testing.
  No real person, business, or policy is described.</p>
</body>
</html>
