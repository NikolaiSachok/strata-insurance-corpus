<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>{{ policy_id }} — Declarations</title></head>
<body>
  <div class="synthetic-banner">{{ marker }}</div>
  <div class="masthead">
    <div class="company">{{ company }}</div>
    <div class="doc-title">{{ doc_title }}</div>
  </div>

  <h2>Policy Declarations</h2>
  <table class="kv">
    <tr><td class="k">Policy number</td><td class="v">{{ policy_id }}</td></tr>
    <tr><td class="k">Line of business</td><td class="v">{{ line_label }}</td></tr>
    <tr><td class="k">Named insured</td><td class="v">{{ holder_name }}</td></tr>
    <tr><td class="k">Mailing address</td><td class="v">{{ holder_address }}</td></tr>
    <tr><td class="k">Policy period</td><td class="v">{{ effective_date }} to {{ expiry_date }}</td></tr>
    <tr><td class="k">Producing agent</td><td class="v">{{ agent_name }} — {{ agency }}</td></tr>
    <tr><td class="k">Annual premium</td><td class="v">{{ annual_premium }}</td></tr>
    <tr><td class="k">Deductible</td><td class="v">{{ deductible }}</td></tr>
  </table>

  <h2>Limits of Insurance</h2>
  <table class="grid">
    <thead><tr><th>Coverage</th><th>Limit</th></tr></thead>
    <tbody>
    {% for label, value in limits %}
      <tr><td>{{ label }}</td><td>{{ value }}</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Endorsements</h2>
  <p class="clause">{{ endorsements }}</p>
  <p class="clause">The full policy contract, endorsement schedule, and coverage schedule are issued
  as separate forms under policy {{ policy_id }}.</p>

  <p class="meta-foot">This document is synthetic and generated for retrieval/benchmark testing.
  No real person, business, or policy is described.</p>
</body>
</html>
